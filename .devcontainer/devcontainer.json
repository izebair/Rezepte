{
  "name": "rezepte-onenote-desktop-mvp",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/onenote-desktop-mvp",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspaces/onenote-desktop-mvp,type=bind,consistency=cached",
    "source=${localEnv:USERPROFILE}\\.codex,target=/home/vscode/.codex,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "CODEX_HOME": "/home/vscode/.codex"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "tests"
        ]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
